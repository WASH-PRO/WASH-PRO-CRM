# =============================================================================
# WASH PRO CRM — Environment Variables
# Copy to .env and adjust before deployment
# =============================================================================

# --- Dashboard ---
DASHBOARD_PORT=80

# --- Dynamic API (внешний доступ) ---
DYNAMIC_API_PORT=3001
DYNAMIC_API_PANEL_PORT=8080
# CORS: через запятую — Dashboard, API и панель Dynamic API
CORS_ORIGIN=http://localhost,http://localhost:3001,http://localhost:8080

# --- Dynamic API Backend ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
CSRF_SECRET=change-me-csrf-secret
ADMIN_LOGIN=admin
ADMIN_EMAIL=admin@wash-pro-crm.local
ADMIN_PASSWORD=Admin123!
# Версия vendored Dynamic API Platform (отображается в /api/health и панели)
DYNAMIC_API_VERSION=1.5.6
# In-app updater отключён — обновление через ./scripts/update-dynamic-api.sh
UPDATE_EXECUTOR_ENABLED=false

# --- Внутренние сервисы (service account) ---
SERVICE_LOGIN=service
SERVICE_PASSWORD=ServiceInternal123!

# --- RabbitMQ ---
RABBITMQ_USER=wash
RABBITMQ_PASSWORD=wash_secret_change_me
# Опционально: порт для контроллеров автомоек (пусто = только внутренняя сеть)
RABBITMQ_EXTERNAL_PORT=

# --- Redis (опционально) ---
REDIS_ENABLED=false
REDIS_PASSWORD=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# --- Backup ---
BACKUP_RETENTION_COUNT=7
BACKUP_CRON=0 2 * * *

# --- Версионирование ---
APP_VERSION=1.0.0
