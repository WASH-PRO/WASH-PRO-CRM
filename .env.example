# =============================================================================
# WASH PRO CRM — Environment Variables
# Copy to .env and adjust before deployment
# =============================================================================

# --- Постоянные данные (MongoDB, MQTT, PyOrchestrator, бэкапы) ---
# Каталог на хосте: bind mount, не удаляется при docker compose down / --build
DATA_DIR=./data
# Для автообновления из контейнера (обычно не нужно — определяется автоматически):
# WASH_HOST_PROJECT_ROOT=/absolute/path/to/WASH-PRO-CRM
# WASH_BUILD_ROOT=/deploy
# Production: вынести за пределы репозитория, например:
# DATA_DIR=/var/lib/wash-pro-crm
# DATA_DIR=/mnt/hdd/data

# --- Dashboard ---
DASHBOARD_PORT=80

# --- Dynamic API (внешний доступ) ---
DYNAMIC_API_PORT=3001
DYNAMIC_API_PANEL_PORT=8080
# CORS: через запятую — Dashboard, API и панель Dynamic API
CORS_ORIGIN=http://localhost,http://localhost:3001,http://localhost:8080

# --- Dynamic API Backend ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
CSRF_SECRET=change-me-csrf-secret
ADMIN_LOGIN=admin
ADMIN_EMAIL=admin@wash-pro-crm.local
ADMIN_PASSWORD=Admin123!
# Опционально: принудительная версия Dynamic API (по умолчанию — из dynamic-api/backend/package.json)
# DYNAMIC_API_VERSION=1.5.11
# In-app updater (update-bridge): проверка GitHub и автообновление CRM / Dynamic API / PyOrchestrator
UPDATE_EXECUTOR_ENABLED=true
APP_VERSION=1.1.43
# CRM_GITHUB_REPO=WASH-PRO/WASH-PRO-CRM
# DYNAMIC_API_GITHUB_REPO=Dynamic-API-Platform/Dynamic-API-Platform
# PYORCHESTRATOR_GITHUB_REPO=PyOrchestrator/PyOrchestrator
# GitHub token для release notes и лимита 5000 запросов/ч (опционально; без токена версии проверяются через git ls-remote)
# GITHUB_TOKEN=

# --- Внутренние сервисы (service account) ---
SERVICE_LOGIN=service
SERVICE_PASSWORD=ServiceInternal123!
# Внутренний токен для POST /internal/mqtt/sync-users (по умолчанию = SERVICE_PASSWORD)
# MQTT_SYNC_INTERNAL_TOKEN=

# --- MQTT (телеметрия контроллеров) ---
# Допускаются только system (CRM) и логины постов из карточки поста.
MQTT_USER=system
MQTT_PASSWORD=washpro
# Порт MQTT для контроллеров в локальной сети (0.0.0.0 = все интерфейсы хоста)
MQTT_EXTERNAL_PORT=1883
# Только localhost: MQTT_BIND=127.0.0.1
# Топики подписки message-processor (через запятую, опционально):
# MQTT_TOPICS=wash/telemetry/#,+/+/state/#
# Нативный протокол WASH-PRO (ETH/панель): {dt_pref}/{serial}/state/{suffix}
# MQTT_DEVICE_TOPIC=+/+/#
# Префикс топика по умолчанию для исходящих set/* из CRM:
MQTT_DEVICE_PREFIX=washpro

# --- Redis (опционально) ---
REDIS_ENABLED=false
REDIS_PASSWORD=

# --- Backup ---
BACKUP_RETENTION_COUNT=7
BACKUP_CRON="0 2 * * *"

# --- PyOrchestrator (опционально, как Dynamic API) ---
PYORCHESTRATOR_ENABLED=true
PYORCHESTRATOR_VERSION=0.1.13
PYORCH_BACKEND_PORT=8000
PYORCH_PANEL_PORT=8090
PYORCH_MCP_PORT=8010
# CORS: Dashboard, панель PyOrchestrator
PYORCH_CORS_ORIGINS=http://localhost,http://localhost:8090
PYORCH_JWT_SECRET=jwt-dev-secret-change-in-prod
PYORCH_SECRET_MASTER_KEY=change-me-in-production-32chars!!
PYORCH_INTERNAL_API_KEY=internal-dev-key
PYORCH_POSTGRES_DB=pyorchestrator
PYORCH_POSTGRES_USER=pyorch
PYORCH_POSTGRES_PASSWORD=pyorch_secret
PYORCH_MINIO_ACCESS_KEY=minioadmin
PYORCH_MINIO_SECRET_KEY=minioadmin
PYORCH_MINIO_BUCKET=pyorchestrator
PYORCH_MCP_EMAIL=admin@pyorchestrator.local
PYORCH_MCP_PASSWORD=admin
# Учётные данные PyOrchestrator для раздела Telegram в Dashboard (CRM settings pyorchestrator)
PYORCH_DASHBOARD_EMAIL=admin@pyorchestrator.local
PYORCH_DASHBOARD_PASSWORD=admin
# Observability (Prometheus/Grafana/Loki) — профиль pyorch-observability
PYORCH_OBSERVABILITY_ENABLED=false
PYORCH_PROMETHEUS_PORT=9090
PYORCH_GRAFANA_PORT=3000
# PYORCH_GRAFANA_PUBLIC_URL=http://localhost:3000
# PYORCH_GRAFANA_INTERNAL_URL=http://pyorch-grafana:3000
PYORCH_GRAFANA_ADMIN_USER=admin
PYORCH_GRAFANA_ADMIN_PASSWORD=admin

# --- Версионирование ---
APP_VERSION=1.1.43

# --- MCP Server (services/crm-mcp, Cursor / AI agents) ---
# CRM_API_URL=http://localhost:3001
# CRM_DASHBOARD_URL=http://localhost
# CRM_LOGIN=admin
# CRM_PASSWORD=Admin123!
# CRM_API_KEY=dap_xxxxxxxx
