# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.13

# ─── Internal service auth ─────────────────────────────────────────────────────
INTERNAL_API_KEY=internal-dev-key

# ─── Ports ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
# MinIO S3 API only by default. Set to true to enable web console (port 9001).
MINIO_CONSOLE_ENABLED=false
MINIO_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=pyorchestrator
POSTGRES_USER=pyorch
POSTGRES_PASSWORD=pyorch_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL is built in compose from service name

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pyorchestrator
# MINIO_CONSOLE_PUBLIC_URL=http://localhost:9001

# ─── Security (CHANGE IN PRODUCTION) ─────────────────────────────────────────
SECRET_MASTER_KEY=change-me-in-production-32chars!!
JWT_SECRET=jwt-dev-secret-change-in-prod
CORS_ORIGINS=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
FRONTEND_TARGET=development

# ─── Runtime Engine ───────────────────────────────────────────────────────────
MAX_CONCURRENT_SANDBOXES=50
DEFAULT_MAX_MEMORY_MB=512
DEFAULT_MAX_CPU_SECONDS=300
DEFAULT_WALL_TIMEOUT_SEC=3600
RUNTIME_REPLICAS=1

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Public URL for dashboard link (leave empty to hide Observability panel when Grafana is down)
# GRAFANA_PUBLIC_URL=http://localhost:3000
GRAFANA_INTERNAL_URL=http://grafana:3000

# ─── OTA Updates ─────────────────────────────────────────────────────────────
GITHUB_UPDATE_REPO=PyOrchestrator/PyOrchestrator
# GITHUB_UPDATE_TOKEN=
UPDATE_EXECUTOR_ENABLED=true
UPDATE_DEPLOY_MODE=docker
# UPDATE_RUNNER_IMAGE=docker:26-cli
# Optional: override auto-detected host project path (normally not needed).
# The backend detects the real path from the /deploy volume mount on any machine.
# PYORCH_HOST_PROJECT_ROOT=
